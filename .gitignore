# Master Gitignore for Webhook Delivery System

# Environment Variables (Crucial!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/ .env

# Dependencies
node_modules/
**/node_modules/

# Build Outputs
dist/
build/
**/dist/
**/build/

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS Files
.DS_Store
Thumbs.db
Desktop.ini

# IDEs
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
